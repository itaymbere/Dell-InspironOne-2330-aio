	background = true,
	font = 'FuraCode Nerd Font:pixelsize=9',
	use_xft = true,

	xftalpha = 0.1,
	update_interval = 5,
	total_run_times = 0,

	own_window = true,
	own_window_type = 'normal',
	own_window_transparent = true,
	own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',
	own_window_colour = '000000',
	own_window_argb_visual = true,
	own_window_argb_value = 0,

	double_buffer = true,
	--minimum_size 250 5
	--maximum_width 800
	--maximum_height 800
	draw_shades = false,
	draw_outline = false,
	draw_borders = false,
	draw_graph_borders = false,
	default_color = 'white',
	default_shade_color = 'red',
	default_outline_color = 'green',
	alignment = 'bottom_right',
	gap_x = 0,
	gap_y = 0,
	no_buffers = true,
	uppercase = false,
	cpu_avg_samples = 2,
	net_avg_samples = 1,
	override_utf8_locale = true,
	use_spacer = 'no',


	minimum_width = 400, minimum_height = 400,
};

conky.text = [[
${voffset 0}${offset 0}${font Ubuntu:pixelsize=12}${color FFA300}HD ${offset 9}$color${fs_free /}/${fs_size /}${offset 30}${color FFA300}RAM ${offset 9}$color$mem / $memmax${offset 30}${color FFA300}CPU ${offset 9}$color${cpu cpu0}% ${cpu cpu1}% ${cpu cpu2}% ${cpu cpu3}% ${offset 20}${color FFA300}Pkg $color${execi 2 sensors | awk '/Package id 0/ {print $4}'}
${voffset 0}${offset 0}${font Ubuntu:pixelsize=12}${offset 0}${color FFA300}MB temp$color ${execi 2 sensors | awk '/CPU/ {print $2}'}${offset 10}${color FFA300}Core temp ${offset 9}$color${execi 2 sensors | awk '/Core 0/ {print $3}'}/${execi 2 sensors | awk '/Core 1/ {print $3}'}/${execi 2 sensors | awk '/Core 2/ {print $3}'}/${execi 2 sensors | awk '/Core 3/ {print $3}'} ${color FFA300}min/max $color(${execi 2 sensors | awk '/Core 3/ {print $6}'}${execi 2 sensors | awk '/Core 3/ {print $9}'}
${voffset 0}${offset 0}${font Ubuntu:pixelsize=12}${color FFA300}FANs $color${offset 9}${color FFA300}CPU fans$color${offset 9}${execi 2 sensors | awk '/Processor Fan/ {print $3}' | sed -n '1p'}/${execi 2 sensors | awk '/Processor Fan/ {print $3}' | sed -n '2p'} ${color FFA300}rpms$color
${voffset 0}${offset 0}${color FFA300}ISA fans ${offset 9}$color${offset 9}${execi 2 sensors | awk '/fan1/ {print $2}'}/$color${execi 2 sensors | awk '/fan2/ {print $2}'}/$color${execi 2 sensors | awk '/fan3/ {print $2}'} ${color FFA300}rpms$color
${voffset 0}${offset 0}${color FFA300}ISA Temps$color${offset 9}${execi 2 sensors | awk '/fan1/ {print $2}'} ${color FFA300}2 $color${execi 2 sensors | awk '/fan2/ {print $2}'} ${color FFA300}3 $color$color$color${execi 2 sensors | awk '/temp3/ {print $2}'}
${voffset 0}${offset 0}${color FFA300}ACPCI Temps ${offset 9}$color${offset 9}${color FFA300}1 $color${execi 2 sensors | awk '/temp1/ {print $2}' | sed -n '1p'} ${color FFA300}2 $color${execi 2 sensors | awk '/temp2/ {print $2}' | sed -n '2p'}
${voffset 0}${offset 0}${font Ubuntu:pixelsize=12}${color FFA300}Power ${offset 9}$color${execi 2 sensors | awk '/in1/ {print $2}'}${color FFA300}V$color ${execi 2 sensors | awk '/in2/ {print $2}'}${color FFA300}mV$color ${execi 2 sensors | awk '/in3/ {print $2}'}${color FFA300}mV$color ${execi 2 sensors | awk '/in4/ {print $2}'}${color FFA300}mV$color ${execi 2 sensors | awk '/in5/ {print $2}'}${color FFA300}V$color ${execi 2 sensors | awk '/in6/ {print $2}'}${color FFA300}V$color
${voffset 0}${offset 0}${font Ubuntu:pixelsize=12}${color FFA300}CPU pwm${offset 9}$color${color FFA300}1$color ${execi 2 sensors | grep pwm | awk '/pwm1/ {print $2}'| sed -n '1p'}${offset 9}${color FFA300}2$color ${execi 2 sensors | grep pwm | awk '/pwm2/ {print $2}'| sed -n '1p'}${offset 30}${color FFA300}ISA pwm${offset 9}$color${color FFA300}1$color ${execi 2 sensors | awk '/pwm1/ {print $2}' | sed -n '2p'}${offset 9}${color FFA300}2$color ${execi 2 sensors | awk '/pwm2/ {print $2}' | sed -n '2p'}${offset 9}${color FFA300}3$color ${execi 2 sensors | awk '/pwm3/ {print $2}'}
${alignr}${offset 0}< ${fs_used_perc}% > Root < ${color #BEC8CB}${fs_bar 5,120 /}${color} >${offset 10}
${alignr}${offset 0}< ${fs_used_perc /home}% > Home < ${color #BEC8CB}${fs_bar 5,120 /home}${color} >${offset 10}
${alignr}${offset 0}<  ${swapperc}% > Swap < ${color #BEC8CB}${swapbar 5,120}${color} >${offset 10}
${font Ubuntu:pixelsize=12}${color FFA300}ETH $color enp4s0
${offset 15}${font Ubuntu:size=7,weight:bold}${color1}${color1}Up:${alignr}${font Ubuntu:size=7,weight:normal}$color2${upspeed wlp2s0} / ${totalup}
${offset 15}${upspeedgraph wlp2s0 40,500 4B1B0C FF5C2B 100 -l}
${offset 15}${color1}${font Ubuntu:size=7,weight:bold}Down: ${alignr}${font Ubuntu:size=7,weight:normal}$color2${downspeed wlp2s0} / ${totaldown}
${offset 15}${downspeedgraph wlp2s0 40,500 324D23 77B753 100 -l}
]];

























































































